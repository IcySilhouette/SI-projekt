{% extends 'base.html.twig' %}

{% block title %}Edycja użytkownika{% endblock %}

{% block body %}
    <h1>Edycja użytkownika: {{ user.email }}</h1>

    <div style="max-width: 600px; background-color: #f8f9fa; color: #212529; padding: 25px; border-radius: 6px; border: 1px solid #e3e6f0; margin-top: 20px;">
        <form method="POST" onsubmit="return confirm('{{ 'message.confirm_user_edit'|trans }}');">

            <div style="margin-bottom: 15px;">
                <label for="user_email" style="display: block; font-weight: bold; margin-bottom: 5px; color: #212529;">Nowy adres E-mail:</label>
                <input type="email" id="user_email" name="email" value="{{ user.email }}" required style="width: 100%; padding: 8px; box-sizing: border-box; border: 1px solid #ccc; border-radius: 4px; color: #212529; background-color: #ffffff;">
            </div>

            <div style="margin-bottom: 25px;">
                <label for="user_is_admin" style="font-weight: bold; display: flex; align-items: center; cursor: pointer; color: #212529;">
                    <input type="checkbox" id="user_is_admin" name="is_admin" value="1" {% if 'ROLE_ADMIN' in user.roles %}checked{% endif %} style="margin-right: 10px; width: 18px; height: 18px;">
                    Nadać uprawnienia Administratora (ROLE_ADMIN)
                </label>
            </div>

            <button type="submit" style="background-color: #28a745; color: white; padding: 10px 15px; border: none; border-radius: 4px; font-size: 15px; cursor: pointer;">
                Zapisz zmiany
            </button>
            <a href="{{ path('app_admin_user_index') }}" style="margin-left: 15px; color: #495057; text-decoration: none;">Anuluj</a>
        </form>
    </div>
{% endblock %}
