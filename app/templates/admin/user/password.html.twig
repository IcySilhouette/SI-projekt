{% extends 'base.html.twig' %}

{% block title %}Wymuszenie zmiany hasła{% endblock %}

{% block body %}
    <h1>Zmień hasło użytkownikowi: {{ user.email }}</h1>
    <p style="color: #6c757d;">Jako administrator zmieniasz hasło bezpośrednio, bez podawania starego hasła użytkownika.</p>

    <div style="max-width: 600px; background-color: #f8f9fa; padding: 25px; border-radius: 6px; border: 1px solid #e3e6f0; margin-top: 20px;">
        <form method="POST" onsubmit="return confirm('{{ 'message.confirm_password_change'|trans }}');">
            <div style="margin-bottom: 20px;">
                <label for="new_password_input" style="display: block; font-weight: bold; margin-bottom: 5px; color: #000000 !important;">
                    Wpisz nowe hasło dla użytkownika:
                </label>
                <input type="password" id="new_password_input" name="new_password" required minlength="6" style="width: 100%; padding: 8px; box-sizing: border-box; border: 1px solid #ccc; border-radius: 4px; color: #000000;">
            </div>

            <button type="submit" style="background-color: #dc3545; color: white; padding: 10px 15px; border: none; border-radius: 4px; font-size: 15px; cursor: pointer;">Zmień hasło</button>
            <a href="{{ path('app_admin_user_index') }}" style="margin-left: 15px; color: #6c757d; text-decoration: none;">Anuluj</a>
        </form>
    </div>
{% endblock %}
