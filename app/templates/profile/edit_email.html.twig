{% extends 'base.html.twig' %}

{% block title %}Zmień adres E-mail{% endblock %}

{% block body %}
    <div class="row justify-content-center my-4">
        <div class="col-lg-7">

            <div class="card bg-dark text-light border-info border-2 shadow-lg rounded-3">

                <div class="card-header border-secondary bg-dark py-3 px-4">
                    <h1 class="h3 mb-0 text-info fw-bold text-uppercase tracking-wide">
                        <i class="bi bi-envelope-plus me-2"></i>Zmień adres E-mail
                    </h1>
                </div>

                <div class="card-body p-4 bg-dark">
                    <form method="post">

                        <div class="p-4 rounded-3 border border-secondary mb-4 bg-secondary bg-opacity-10 shadow-inner">

                            <div class="mb-3">
                                <label for="email" class="form-label text-white-50 small text-uppercase fw-bold tracking-wider opacity-75">
                                    Nowy adres E-mail
                                </label>

                                <div class="input-group">
                                <span class="input-group-text bg-info bg-opacity-10 text-info border-secondary">
                                    <i class="bi bi-envelope-fill"></i>
                                </span>
                                    <input type="email" name="email" id="email"
                                           class="form-control bg-dark text-light border-secondary focus-info"
                                           value="{{ app.user.email }}" required>
                                </div>

                                <div class="form-text text-white-50 opacity-50 mt-2 small">
                                    <i class="bi bi-info-circle me-1"></i>Na ten adres będą wysyłane powiadomienia systemowe.
                                </div>
                            </div>

                        </div>

                        <hr class="border-secondary my-4">

                        <div class="d-flex flex-column flex-sm-row justify-content-between gap-3">

                            <a href="{{ path('app_profile') }}" class="btn btn-outline-light text-nowrap px-3 py-2 rounded-3">
                                <i class="bi bi-arrow-left me-1"></i>Anuluj i wróć
                            </a>

                            <button type="submit" class="btn btn-info text-dark fw-bold px-4 py-2 shadow rounded-3">
                                <i class="bi bi-check-lg me-1"></i>Zapisz nowy e-mail
                            </button>

                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>

    <style>
        .focus-info:focus {
            background-color: #212529 !important;
            color: #fff !important;
            border-color: #0dcaf0 !important;
            box-shadow: 0 0 0 0.25rem rgba(13, 202, 240, 0.25) !important;
        }
    </style>
{% endblock %}
