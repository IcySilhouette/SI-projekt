{% extends 'base.html.twig' %}

{% block title %}Zmiana hasła{% endblock %}

{% block body %}
    <div class="row justify-content-center my-4">
        <div class="col-lg-7">
            <div class="card bg-dark text-light border-info border-2 shadow-lg rounded-3">

                <div class="card-header border-secondary bg-dark py-3 px-4">
                    <h1 class="h3 mb-0 text-info fw-bold text-uppercase tracking-wide">
                        <i class="bi bi-key-fill me-2"></i>Zmiana hasła
                    </h1>
                </div>

                <div class="card-body p-4 bg-dark">
                    <form method="post">

                        <div class="mb-4">
                            <label for="current_password" class="form-label text-white-50">Aktualne hasło</label>
                            <input type="password" name="current_password" id="current_password" class="form-control bg-dark text-light border-secondary" required>
                        </div>

                        <div class="mb-4">
                            <label for="new_password" class="form-label text-white-50">Nowe hasło</label>
                            <input type="password" name="new_password" id="new_password" class="form-control bg-dark text-light border-secondary" required>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <a href="{{ path('app_profile') }}" class="btn btn-outline-light">Anuluj</a>
                            <button type="submit" class="btn btn-info text-dark fw-bold px-4">Zapisz nowe hasło</button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
