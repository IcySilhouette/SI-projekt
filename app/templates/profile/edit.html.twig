{% extends 'base.html.twig' %}

{% block title %}Edycja profilu{% endblock %}

{% block body %}
<h1>Edycja danych konta</h1>

{{ form_start(form) }}
{{ form_widget(form) }}
<button class="btn btn-success" style="margin-top: 15px;">{{ 'action.save'|trans|default('Zapisz') }}</button>
{{ form_end(form) }}

<hr style="margin: 30px 0;">
<a href="{{ path('app_profile_change_password') }}" class="btn btn-primary">Zmień hasło konta</a>

{% endblock %}
