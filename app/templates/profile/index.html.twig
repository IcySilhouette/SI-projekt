{% extends 'base.html.twig' %}

{% block title %}Mój profil{% endblock %}

{% block body %}
    <div class="row justify-content-center my-4">
        <div class="col-lg-7">

            <div class="card bg-dark text-light border-info border-2 shadow-lg rounded-3">

                <div class="card-header border-secondary bg-dark py-3 px-4">
                    <h1 class="h3 mb-0 text-info fw-bold text-uppercase tracking-wide">
                        <i class="bi bi-person-bounding-box me-2"></i>Mój profil
                    </h1>
                </div>

                <div class="card-body p-4 bg-dark">

                    <div class="p-4 rounded-3 border border-secondary mb-4 bg-secondary bg-opacity-10 shadow-inner">
                        <h5 class="text-info small text-uppercase fw-bold mb-4 tracking-wider opacity-75">
                            <i class="bi bi-shield-lock-fill me-1"></i> Dane konta
                        </h5>

                        <div class="d-flex align-items-center mb-3 pb-3 border-bottom border-secondary border-opacity-50">
                            <div class="bg-info bg-opacity-10 text-info rounded p-2 me-3">
                                <i class="bi bi-envelope-fill fs-5"></i>
                            </div>
                            <div>
                                <span class="text-white-50 small d-block">Adres E-mail</span>
                                <strong class="text-light fs-5">{{ app.user.email }}</strong>
                            </div>
                        </div>

                        <div class="d-flex align-items-center">
                            <div class="bg-info bg-opacity-10 text-info rounded p-2 me-3">
                                <i class="bi bi-shield-shaded fs-5"></i>
                            </div>
                            <div>
                                <span class="text-white-50 small d-block mb-1">Twoje uprawnienia</span>
                                <div class="d-flex gap-2 flex-wrap">
                                    {% for role in app.user.roles %}
                                        {% if role == 'ROLE_ADMIN' %}
                                            <span class="badge bg-danger text-white fw-bold px-2.5 py-1.5 shadow-sm text-uppercase">
                                                <i class="bi bi-patch-check-fill me-1"></i>{{ role }}
                                            </span>
                                        {% else %}
                                            <span class="badge bg-info text-dark fw-bold px-2.5 py-1.5 shadow-sm text-uppercase">
                                                {{ role }}
                                            </span>
                                        {% endif %}
                                    {% endfor %}
                                </div>
                            </div>
                        </div>

                    </div>

                    <hr class="border-secondary my-4">

                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">

                        <a href="{{ path('app_article_index') }}" class="btn btn-outline-light text-nowrap order-3 order-md-1">
                            <i class="bi bi-house-door me-1"></i>Powrót do strony głównej
                        </a>

                        <div class="d-flex flex-column flex-sm-row gap-2 order-1 order-md-2 w-100 w-md-auto justify-content-end">

                            <a href="{{ path('app_profile_edit_email') }}" class="btn btn-outline-info fw-bold px-3 py-2 shadow rounded-3">
                                <i class="bi bi-envelope-plus me-2"></i>Zmień adres E-mail
                            </a>

                            <a href="{{ path('app_profile_change_password') }}" class="btn btn-info text-dark fw-bold px-3 py-2 shadow rounded-3">
                                <i class="bi bi-key-fill me-2"></i>Zmień hasło
                            </a>

                        </div>

                    </div>

                </div>
            </div>

        </div>
    </div>
{% endblock %}
