{% extends 'base.html.twig' %}

{% block title %}{{ 'title.article_index'|trans }}{% endblock %}

{% block body %}
    {% if tagName is defined and tagName is not empty %}
        <div class="alert alert-dark border-info d-flex align-items-center justify-content-between shadow-sm border-2 mb-4" role="alert">
            <div>
                <i class="bi bi-funnel-fill text-info me-2"></i>
                Filtrujesz po tagu: <span class="badge bg-info text-dark fw-bold px-2 py-1">{{ tagName }}</span>
            </div>
            <a href="{{ path('app_article_index') }}" class="btn btn-sm btn-outline-info text-decoration-none">
                <i class="bi bi-x-circle me-1"></i>Pokaż wszystkie
            </a>
        </div>
    {% elseif categoryName is defined and categoryName is not empty %}
        <div class="alert alert-dark border-info d-flex align-items-center justify-content-between shadow-sm border-2 mb-4" role="alert">
            <div>
                <i class="bi bi-folder-fill text-info me-2"></i>
                Filtrujesz po kategorii: <span class="badge bg-info text-dark fw-bold px-2 py-1">{{ categoryName }}</span>
            </div>
            <a href="{{ path('app_article_index') }}" class="btn btn-sm btn-outline-info text-decoration-none">
                <i class="bi bi-x-circle me-1"></i>Pokaż wszystkie
            </a>
        </div>
    {% endif %}

    <div class="d-flex align-items-center mb-4 border-bottom pb-2">
        <h1 class="h2 text-white fw-bold mb-0">
            <i class="bi bi-journal-text me-2 text-dark"></i>{{ 'title.article_index'|trans }}
        </h1>
    </div>

    <div class="table-responsive rounded shadow-sm border">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark border-bottom border-secondary">
            <tr class="text-uppercase small fw-bold">
                <th style="width: 60px;" class="text-center text-secondary">{{ 'label.id'|trans }}</th>
                <th>{{ 'label.title'|trans }}</th>
                <th>{{ 'label.content'|trans }}</th>
                <th>{{ 'label.created_at'|trans }}</th>
                <th>{{ 'label.author'|trans }}</th>
                <th>Kategoria</th>
                <th>Tagi</th>
                <th class="text-center" style="width: 180px;">{{ 'label.actions'|trans }}</th>
            </tr>
            </thead>
            <tbody>
            {% for article in articles %}
                <tr>
                    <td class="text-center fw-semibold text-muted">{{ article.id }}</td>
                    <td class="fw-bold text-dark">{{ article.title }}</td>
                    <td class="text-secondary text-truncate" style="max-width: 200px;">{{ article.content }}</td>
                    <td class="text-muted small">
                        <i class="bi bi-calendar3 me-1"></i>{{ article.createdAt ? article.createdAt|date('Y-m-d H:i:s') : '' }}
                    </td>
                    <td class="small text-secondary">{{ article.author.email }}</td>

                    <td>
                        {% if article.category %}
                            <a href="{{ path('app_article_by_category', {'id': article.category.id}) }}" class="text-decoration-none fw-semibold link-dark border-bottom border-info border-2 pb-1">
                                {{ article.category.name }}
                            </a>
                        {% else %}
                            <span class="text-muted fst-italic small">brak</span>
                        {% endif %}
                    </td>

                    <td>
                        {% for tag in article.tags %}
                            <a href="{{ path('app_article_by_tag', {'id': tag.id}) }}" class="badge bg-dark text-info border border-secondary text-decoration-none me-1 shadow-sm">
                                <i class="bi bi-tag-fill me-1 small"></i>{{ tag.name }}
                            </a>
                        {% else %}
                            <span class="text-muted fst-italic small">brak</span>
                        {% endfor %}
                    </td>

                    <td class="text-center">
                        <div class="btn-group" role="group" aria-label="Akcje">
                            <a href="{{ path('app_article_show', {'id': article.id}) }}" class="btn btn-sm btn-outline-secondary" title="{{ 'action.show'|trans }}">
                                <i class="bi bi-eye-fill"></i> <span class="d-none d-xl-inline ms-1">{{ 'action.show'|trans }}</span>
                            </a>

                            {% if is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('app_article_edit', {'id': article.id}) }}" class="btn btn-sm btn-outline-dark" title="{{ 'action.edit'|trans }}">
                                    <i class="bi bi-pencil-fill"></i> <span class="d-none d-xl-inline ms-1">{{ 'action.edit'|trans }}</span>
                                </a>
                            {% endif %}
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8" class="text-center py-4 text-muted">
                        <i class="bi bi-inbox display-6 d-block mb-2"></i>
                        {{ 'message.empty_list'|trans }}
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center mt-4 gap-3">

        {% if is_granted('ROLE_ADMIN') %}
            <a href="{{ path('app_article_new') }}" class="btn btn-dark border-info text-info fw-bold px-4 py-2 shadow-sm order-2 order-sm-1">
                <i class="bi bi-plus-circle-fill me-2"></i>{{ 'action.create'|trans }}
            </a>
        {% endif %}

        {% if max_pages > 1 %}
            <nav aria-label="Nawigacja stronami" class="order-1 order-sm-2">
                <ul class="pagination pagination-sm mb-0 align-items-center">
                    {% if current_page > 1 %}
                        <li class="page-item">
                            <a href="{{ path('app_article_index', {page: current_page - 1}) }}" class="page-link bg-dark text-info border-secondary shadow-sm">
                                <i class="bi bi-chevron-left"></i> {{ 'label.newer_articles'|trans }}
                            </a>
                        </li>
                    {% endif %}

                    <li class="mx-3 fw-bold text-secondary small">
                        {{ 'label.page'|trans }} <span class="text-dark">{{ current_page }}</span> {{ 'label.of'|trans }} <span class="text-dark">{{ max_pages }}</span>
                    </li>

                    {% if current_page < max_pages %}
                        <li class="page-item">
                            <a href="{{ path('app_article_index', {page: current_page + 1}) }}" class="page-link bg-dark text-info border-secondary shadow-sm">
                                {{ 'label.older_articles'|trans }} <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    {% endif %}
                </ul>
            </nav>
        {% endif %}
    </div>
{% endblock %}
